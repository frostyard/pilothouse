{
  "name": "pilothouse",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "golang.go",
        "a-h.templ"
      ],
      "settings": {
        "go.useLanguageServer": true,
        "go.toolsManagement.checkForUpdates": "off"
      }
    }
  },
  "postCreateCommand": "go mod download && go tool templ generate"
}
